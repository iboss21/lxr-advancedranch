# JSON fallback store
data/
*.json.bak

# Logs
*.log
logs/
debug.log
error.log

# OS detritus
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.nfs*

# Editor / IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# Build artifacts / Tebex packaging
*.zip
!lxr-advancedranch.zip
build/
dist/
out/

# Local env / secrets
.env
.env.local
.env.*.local
secrets.txt
*.key
*.pem

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.orig

# Node (NUI dev if anyone wires one up)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# FXServer cache (if repo is checked out inside resources/)
cache/
crashes/
