# Runtime & cache
logs/
cache/
*.log

# Node / tooling
node_modules/
.npm/

# IDE
.idea/
.vscode/
*.suo
*.user

# Build artifacts
build/
dist/
out/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

